kind:       HTTPRoute
apiVersion: gateway.networking.k8s.io/v1

metadata:
  name:      argo-cd
  namespace: argo-cd

spec:
  parentRefs:
    - name:        traefik-gateway
      namespace:   traefik
      sectionName: web

  hostnames:
    - argo-cd.localhost

  rules:
    - backendRefs:
        - name: argo-cd-server
          port: 443    ## service port 8080 not found
